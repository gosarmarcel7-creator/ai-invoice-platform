# Frontend / Next.js
# Leave blank to use the same-origin Next.js API routes.
NEXT_PUBLIC_API_URL=

# Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key
NEXT_PUBLIC_ADMIN_HOST=a-app.docuextract.xyz

# Comma-separated list of bootstrap admin emails.
# These users can access the admin console before the admin_users table is populated.
ADMIN_BOOTSTRAP_EMAILS=owner@docuextract.xyz

# Optional. Only needed if you later wire a privileged webhook dispatcher.
SUPABASE_SERVICE_ROLE_KEY=

# Mistral AI
# Required for real AI extraction. Leave blank only if you want invoice uploads to fail instead of inventing data.
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-large-latest

# Optional outbound webhook dispatcher settings
INVOICE_WEBHOOK_TARGET_URL=
INVOICE_WEBHOOK_SECRET=

# Backend / FastAPI
# Leave blank to use local SQLite for development.
DATABASE_URL=sqlite:///./invoices.db

# Supabase JWT secret for verifying user access tokens in the backend
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
