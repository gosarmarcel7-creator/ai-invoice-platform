# Backend API URL.
# Leave blank to use the same-origin Next.js API routes.
NEXT_PUBLIC_API_URL=

# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key
NEXT_PUBLIC_ADMIN_HOST=a-app.docuextract.xyz

# Comma-separated list of bootstrap admin emails.
ADMIN_BOOTSTRAP_EMAILS=owner@docuextract.xyz

# Optional. Used by server routes that need admin Supabase access, including password reset link generation.
SUPABASE_SERVICE_ROLE_KEY=

# AI extraction provider — optional; blank falls back to mock extraction locally.
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-large-latest

# Mailjet transactional email
MAILJET_API_KEY=
MAILJET_API_SECRET=
MAILJET_FROM_EMAIL=no-reply@docuextract.xyz
MAILJET_FROM_NAME=DocuExtract

# Optional outbound webhook dispatcher settings
INVOICE_WEBHOOK_TARGET_URL=
INVOICE_WEBHOOK_SECRET=
