# Backend API URL.
# Leave blank to use the same-origin Next.js API routes.
NEXT_PUBLIC_API_URL=

# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key

# Optional. Only needed if you later wire a privileged webhook dispatcher.
SUPABASE_SERVICE_ROLE_KEY=

# Mistral AI — optional; blank falls back to mock extraction locally.
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-large-latest

# Optional outbound webhook dispatcher settings
INVOICE_WEBHOOK_TARGET_URL=
INVOICE_WEBHOOK_SECRET=
