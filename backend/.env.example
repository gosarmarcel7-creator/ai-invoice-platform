# Mistral AI — from console.mistral.ai
# Leave blank to use mock extraction locally.
MISTRAL_API_KEY=

# Optional model override. Defaults to mistral-large-latest.
MISTRAL_MODEL=mistral-large-latest

# Database — leave blank to use SQLite locally.
# For Supabase: Settings → Database → Connection string (URI mode).
DATABASE_URL=sqlite:///./invoices.db

# Supabase JWT secret — Settings → API → JWT Settings → JWT Secret.
# Required for per-user invoice scoping.
SUPABASE_JWT_SECRET=
